<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_papachina" model="ir.module.category">
            <field name="name">PapaChina Workplace</field>
            <field name="description">PapaChina internal workplace system</field>
            <field name="sequence">5</field>
        </record>

        <record id="group_ms_customer_service" model="res.groups">
            <field name="name">Customer Service</field>
            <field name="comment">Search and view customer profiles and enquiries; cannot delete.</field>
        </record>

        <record id="group_ms_customer_admin" model="res.groups">
            <field name="name">Customer Admin</field>
            <field name="implied_ids" eval="[(4, ref('group_ms_customer_service'))]"/>
            <field name="comment">Full access to customer profiles, enquiries, country email configuration and block history.</field>
        </record>

    </data>
</odoo>
