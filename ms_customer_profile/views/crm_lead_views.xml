<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead_form_inherit_ms_customer" model="ir.ui.view">
        <field name="name">crm.lead.form.ms_customer</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <h2>
                    <field name="enquiry_reference_id" readonly="1"/>
                </h2>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="account_type"/>
                <field name="source_website_id" options="{'no_create': True}"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Enquiry Products" name="enquiry_products">
                    <field name="enquiry_product_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="image" widget="image" options="{'size': [60, 60]}"/>
                            <field name="name"/>
                            <field name="model_number"/>
                            <field name="quantity"/>
                            <field name="source_url" widget="url"/>
                        </list>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name"/>
                                        <field name="model_number"/>
                                        <field name="quantity"/>
                                    </group>
                                    <group>
                                        <field name="image" widget="image"/>
                                        <field name="source_url" widget="url"/>
                                    </group>
                                </group>
                                <group string="Description">
                                    <field name="description" nolabel="1"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_enquiry_dashboard_list" model="ir.ui.view">
        <field name="name">crm.lead.enquiry.dashboard.list</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <list string="Enquiries">
                <field name="create_date" string="Date" widget="date"/>
                <field name="enquiry_reference_id"/>
                <field name="partner_name" string="Company"/>
                <field name="contact_name" string="Customer"/>
                <field name="email_from" string="Email"/>
                <field name="country_id"/>
                <field name="account_type" string="Promotional Type"/>
                <field name="product_count" string="# Products"/>
                <field name="source_website_id" string="Source Website" optional="show"/>
                <field name="user_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_enquiry_dashboard_search" model="ir.ui.view">
        <field name="name">crm.lead.enquiry.dashboard.search</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <search string="Enquiries">
                <field name="enquiry_reference_id"/>
                <field name="partner_name"/>
                <field name="contact_name"/>
                <field name="email_from"/>
                <field name="country_id"/>
                <field name="source_website_id"/>
                <separator/>
                <filter name="end_customer" string="End Customer"
                        domain="[('account_type','=','end_customer')]"/>
                <filter name="reseller" string="Reseller"
                        domain="[('account_type','=','reseller')]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_week" string="This Week"
                        domain="[('create_date', '&gt;=', (context_today()-relativedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_country" string="Country" context="{'group_by': 'country_id'}"/>
                    <filter name="group_website" string="Source Website" context="{'group_by': 'source_website_id'}"/>
                    <filter name="group_account_type" string="Promotional Type" context="{'group_by': 'account_type'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_enquiry_dashboard" model="ir.actions.act_window">
        <field name="name">All Enquiries</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type','=','opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
        <field name="search_view_id" ref="view_enquiry_dashboard_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_enquiry_dashboard_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('crm.crm_lead_view_form')})]"/>
    </record>

</odoo>
