<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_customer_block_history_list" model="ir.ui.view">
        <field name="name">ms_customer.block_history.list</field>
        <field name="model">ms_customer.block_history</field>
        <field name="arch" type="xml">
            <list string="Block History" create="false" edit="false" delete="false">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="action"/>
                <field name="reason"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_customer_block_history_search" model="ir.ui.view">
        <field name="name">ms_customer.block_history.search</field>
        <field name="model">ms_customer.block_history</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter name="action_block" string="Blocked" domain="[('action','=','block')]"/>
                <filter name="action_unblock" string="Unblocked" domain="[('action','=','unblock')]"/>
                <group>
                    <filter name="group_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_action" string="Action" context="{'group_by': 'action'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_customer_block_history" model="ir.actions.act_window">
        <field name="name">Block / Unblock History</field>
        <field name="res_model">ms_customer.block_history</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
